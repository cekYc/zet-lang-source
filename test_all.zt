// --- 10.1: Basit return ---
det fn basit_return() -> i64 {
    return 42
}

// --- 10.2: Kosullu return ---
det fn kosullu_return(n: i64) -> i64 {
    if n > 0 {
        return n
    }
    return 0 - n
}

// --- 10.3: Void return ---
det fn void_return_testi() -> Void {
    println("  [RETURN] Bu fonksiyon Void donduruyor.")
    return
}

// --- 10.4: Dallanmali return ---
det fn not_hesapla(puan: i64) -> String {
    if puan >= 90 {
        return "AA"
    } else {
        if puan >= 80 {
            return "BA"
        } else {
            if puan >= 70 {
                return "BB"
            } else {
                if puan >= 60 {
                    return "CB"
                } else {
                    return "FF"
                }
            }
        }
    }
}

