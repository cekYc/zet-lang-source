// --- 8.1: Degisken parametreli validate ---
nondet fn validate_parametre_testi(veri: Untrusted) -> Void {
    println("  [VALIDATE] Parametre testi:")
    validate veri {
        success: {
            println("    Dogrulandi: " + veri)
        }
    }
}

// --- 8.2: Validate icinde hesaplama ---
nondet fn validate_hesap_testi(girdi: Untrusted) -> Void {
    println("  [VALIDATE-CALC] Validate icinde hesaplama:")
    validate girdi {
        success: {
            let sayi = call Util.to_int(girdi)
            let kare = sayi * sayi
            println("    Girdi: " + girdi)
            println("    Karesi: " + kare)
        }
    }
}

// --- 8.3: Validate ile isim kontrolu ---
nondet fn validate_isim_testi(isim: Untrusted) -> Void {
    println("  [VALIDATE-NAME] Isim dogrulama:")
    validate isim {
        success: {
            println("    Hosgeldiniz, " + isim + "!")
        }
    }
}

