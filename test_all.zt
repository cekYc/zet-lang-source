// --- 2.1: Basit nondet fonksiyon ---
nondet fn zaman_damgasi() -> i64 {
    let t = call Util.now()
    return t
}

// --- 2.2: Nondet fonksiyondan det fonksiyon cagrisi ---
nondet fn hesap_ve_yazdir() -> Void {
    let sonuc = topla(100, 200)
    println("  [NONDET] Det fonksiyon sonucu: " + sonuc)
    
    let fib_sonuc = fibonacci(10)
    println("  [NONDET] Fibonacci(10) = " + fib_sonuc)
    
    let fak_sonuc = faktoriyel(6)
    println("  [NONDET] 6! = " + fak_sonuc)
}

// --- 2.3: Nondet fonksiyondan nondet fonksiyon cagrisi ---
nondet fn zaman_olc() -> i64 {
    let baslangic = call Util.now()
    let bitis = call Util.now()
    return bitis - baslangic
}

// --- 2.4: Util.to_int kullanimi ---
nondet fn metin_to_sayi() -> Void {
    let sayi = call Util.to_int("42")
    println("  [NONDET] String -> i64 donusumu: " + sayi)
    
    let sayi2 = call Util.to_int("100")
    let toplam = sayi + sayi2
    println("  [NONDET] 42 + 100 = " + toplam)
}

