// --- 11.1: Fibonacci benchmark ---
nondet fn benchmark_testi() -> Void {
    println("  [BENCH] Fibonacci(30) benchmark:")
    let t1 = call Util.now()
    let sonuc = fibonacci(30)
    let t2 = call Util.now()
    let sure = t2 - t1
    println("    Sonuc: " + sonuc)
    println("    Sure: " + sure + " ms")
}

// --- 11.2: Faktoriyel tablosu ---
nondet fn faktoriyel_tablosu() -> Void {
    println("  [TABLE] Faktoriyel tablosu (1-10):")
    for i in 1..11 {
        let sonuc = faktoriyel(i)
        println("    " + i + "! = " + sonuc)
    }
}

// --- 11.3: Fibonacci serisi ---
nondet fn fibonacci_serisi() -> Void {
    println("  [FIB-SERIES] Fibonacci(0-15):")
    for i in 0..16 {
        let sonuc = fibonacci(i)
        println("    F(" + i + ") = " + sonuc)
    }
}

// --- 11.4: Asal sayi kontrolu ---
nondet fn asal_sayi_testi() -> Void {
    println("  [PRIME] Asal sayi testi (1-30):")
    for i in 1..31 {
        let sonuc = asal_mi(i)
        if sonuc == 1 {
            println("    " + i + " asal!")
        }
    }
}

// --- 11.5: Karsilastirma operatorleri toplu test ---
nondet fn karsilastirma_testi() -> Void {
    println("  [CMP] Karsilastirma operatorleri:")
    println("    5 == 5 ? " + esit_mi(5, 5))
    println("    5 != 3 ? " + farkli_mi(5, 3))
    println("    7 > 3  ? " + buyuk_mu(7, 3))
    println("    2 < 8  ? " + kucuk_mu(2, 8))
    println("    5 >= 5 ? " + buyuk_esit_mi(5, 5))
    println("    4 <= 4 ? " + kucuk_esit_mi(4, 4))
    println("    3 == 7 ? " + esit_mi(3, 7))
    println("    6 > 9  ? " + buyuk_mu(6, 9))
}

// --- 11.6: Us alma ve GCD ---
nondet fn matematik_testi() -> Void {
    println("  [MATH] Ileri matematik:")
    println("    2^10 = " + us_al(2, 10))
    println("    3^5  = " + us_al(3, 5))
    println("    GCD(48, 18)  = " + gcd(48, 18))
    println("    GCD(100, 75) = " + gcd(100, 75))
    println("    |(-42)| = " + mutlak_deger(0 - 42))
    println("    max(15, 27) = " + maks(15, 27))
    println("    min(15, 27) = " + min_deger(15, 27))
    println("    isaret(-5) = " + isaret(0 - 5))
    println("    isaret(0)  = " + isaret(0))
    println("    isaret(3)  = " + isaret(3))
}

// --- 11.7: Not hesaplama ---
nondet fn not_testi() -> Void {
    println("  [GRADE] Not hesaplama:")
    let puanlar = [95, 85, 75, 65, 45]
    for i in 0..5 {
        let puan = puanlar[i]
        let not_val = not_hesapla(puan)
        let sinif = siniflandir(puan)
        println("    Puan: " + puan + " -> Not: " + not_val + " (Sinif: " + sinif + ")")
    }
}

// --- 11.8: Ic ice fonksiyon zincirleri ---
nondet fn zincir_testi() -> Void {
    println("  [CHAIN] Fonksiyon zincirleri:")
    let a = karmasik_hesap(5)
    println("    karmasik_hesap(5) = " + a)
    
    let b = zincirleme(7)
    println("    zincirleme(7) = " + b)
    
    let c = topla(carp(3, 4), cikar(10, 5))
    println("    (3*4) + (10-5) = " + c)
    
    let d = maks(fibonacci(7), faktoriyel(4))
    println("    max(fib(7), 4!) = " + d)
    
    let e = kare_al(kup_al(2))
    println("    (2^3)^2 = " + e)
}

// --- 11.9: Dizi + Dongu + Hesaplama ---
nondet fn dizi_hesaplama_testi() -> Void {
    println("  [ARRAY-CALC] Dizi ile hesaplamalar:")
    let dizi = [3, 7, 2, 9, 1, 8, 4, 6, 5, 10]
    
    // Manuel toplam
    let toplam = dizi[0] + dizi[1] + dizi[2] + dizi[3] + dizi[4] + dizi[5] + dizi[6] + dizi[7] + dizi[8] + dizi[9]
    println("    Dizi toplami: " + toplam)
    
    // En buyuk - en kucuk (bilinen degerler)
    let en_buyuk = maks(maks(maks(dizi[0], dizi[1]), maks(dizi[2], dizi[3])), maks(maks(dizi[4], dizi[5]), maks(dizi[6], dizi[7])))
    println("    En buyuk (ilk 8): " + en_buyuk)
    
    // Kareler
    println("    Kareler:")
    for i in 0..5 {
        let eleman = dizi[i]
        let karesi = kare_al(eleman)
        println("      " + eleman + "^2 = " + karesi)
    }
}

// --- 11.10: For + While karisimi ---
nondet fn dongu_karisim_testi() -> Void {
    println("  [LOOP-MIX] Dongu karisimi:")
    for i in 1..6 {
        let j = 1
        let satir = "    " + i + ": "
        while j <= i {
            satir = satir + "* "
            j = j + 1
        }
        println(satir)
    }
}

// --- 11.11: Boolean degerler ---
nondet fn boolean_testi() -> Void {
    println("  [BOOL] Boolean testi:")
    let dogru = true
    let yanlis = false
    println("    true degeri: " + dogru)
    println("    false degeri: " + yanlis)
}

// --- 11.12: Scope icinde karmasik islemler ---
nondet fn scope_karmasik_testi() -> Void {
    println("  [SCOPE-ADV] Karmasik scope:")
    let mesaj1 = "Gorev A tamamlandi"
    let mesaj2 = "Gorev B tamamlandi"
    let mesaj3 = "Gorev C tamamlandi"
    
    scope GorevYonetici {
        spawn println("    [A] " + mesaj1)
        spawn println("    [B] " + mesaj2)
        spawn println("    [C] " + mesaj3)
    }
    println("  [SCOPE-ADV] Tum gorevler bitti!")
}

// --- 11.13: Validate icinde karmasik islem ---
nondet fn validate_karmasik_testi(veri: Untrusted) -> Void {
    println("  [VALIDATE-ADV] Karmasik validate:")
    validate veri {
        success: {
            let uzunluk = call Util.to_int(veri)
            if uzunluk > 0 {
                println("    Pozitif deger: " + uzunluk)
                let kare = kare_al(uzunluk)
                println("    Karesi: " + kare)
                let kup = kup_al(uzunluk)
                println("    Kupu: " + kup)
            } else {
                println("    Sifir veya negatif.")
            }
        }
    }
}

