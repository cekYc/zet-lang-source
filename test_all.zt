    println("")
    
    // BOLUM 28: Karmasik validate
    println("[BOLUM 28] Karmasik Validate")
    println("------------------------------------------------------------")
    let kv = call input("Bir sayi girin (karmasik test): ")
    call validate_karmasik_testi(kv)
    println("")
    
    println("============================================================")
    println("  TUM TESTLER TAMAMLANDI!")
    println("  Zet Lang v0.3 - Basariyla calisti.")
    println("============================================================")
}
