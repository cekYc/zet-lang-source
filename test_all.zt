// --- 12.1: f64 (ondalikli sayi) ---
det fn topla_f(a: f64, b: f64) -> f64 {
    return a + b
}

det fn carp_f(a: f64, b: f64) -> f64 {
    return a * b
}

det fn daire_alani(r: f64) -> f64 {
    return 3.14159 * r * r
}

nondet fn f64_testi() -> Void {
    println("  [F64] Ondalikli sayi testleri:")
    let a = 3.14
    let b = 2.71
    println("    a = " + a)
    println("    b = " + b)
    println("    topla_f(a, b) = " + topla_f(a, b))
    println("    carp_f(a, b) = " + carp_f(a, b))
    println("    daire_alani(5.0) = " + daire_alani(5.0))
    let c = 10.5 - 3.2
    println("    10.5 - 3.2 = " + c)
    let d = 10.0 / 3.0
    println("    10.0 / 3.0 = " + d)
}

// --- 12.2: char (karakter) ---
nondet fn char_testi() -> Void {
    println("  [CHAR] Karakter testleri:")
    let harf = 'A'
    let rakam = '7'
    let ozel = '!'
    println("    harf = " + harf)
    println("    rakam = " + rakam)
    println("    ozel = " + ozel)
    let mesaj = "Karakter: " + harf
    println("    " + mesaj)
}

// --- 12.3: bool (mantiksal) ---
det fn ve_islemi(a: bool, b: bool) -> bool {
    return a && b
}

det fn veya_islemi(a: bool, b: bool) -> bool {
    return a || b
}

det fn degil_islemi(a: bool) -> bool {
    return !a
}

nondet fn bool_testi_v2() -> Void {
    println("  [BOOL-V2] Bool testi:")
    let d = true
    let y = false
    println("    true && true  = " + ve_islemi(d, d))
    println("    true && false = " + ve_islemi(d, y))
    println("    false || true = " + veya_islemi(y, d))
    println("    false || false= " + veya_islemi(y, y))
    println("    !true  = " + degil_islemi(d))
    println("    !false = " + degil_islemi(y))
}

// ============================================================
// BOLUM 13: YENI OPERATORLER — %, &&, ||, !, &, |, ^, <<, >>
// ============================================================

// --- 13.1: Modulo (%) ---
det fn mod_testi_fn(a: i64, b: i64) -> i64 {
    return a % b
}

nondet fn modulo_testi() -> Void {
    println("  [MOD] Modulo (%) testi:")
    println("    10 % 3 = " + mod_testi_fn(10, 3))
    println("    17 % 5 = " + mod_testi_fn(17, 5))
    println("    100 % 7 = " + mod_testi_fn(100, 7))
    println("    20 % 4 = " + mod_testi_fn(20, 4))
}

// --- 13.2: Mantiksal operatorler (&&, ||, !) ---
nondet fn mantiksal_operator_testi() -> Void {
    println("  [LOGIC] Mantiksal operator testleri:")
    let a = true
    let b = false
    
    // AND
    if a && a {
        println("    true && true = true (dogru)")
    }
    if !(a && b) {
        println("    true && false = false (dogru)")
    }
    
    // OR
    if a || b {
        println("    true || false = true (dogru)")
    }
    if !(b || b) {
        println("    false || false = false (dogru)")
    }
    
    // NOT
    if !b {
        println("    !false = true (dogru)")
    }
    if !(!a) {
        println("    !(!true) = true (dogru)")
    }
    
    // Karmasik
    if (a && !b) || (b && !a) {
        println("    XOR benzeri: (a&&!b)||(b&&!a) = true (dogru)")
    }
}

// --- 13.3: Bitwise operatorler ---
det fn bit_and(a: i64, b: i64) -> i64 {
    return a & b
}

det fn bit_or(a: i64, b: i64) -> i64 {
    return a | b
}

det fn bit_xor(a: i64, b: i64) -> i64 {
    return a ^ b
}

det fn bit_shl(a: i64, n: i64) -> i64 {
    return a << n
}

det fn bit_shr(a: i64, n: i64) -> i64 {
    return a >> n
}

nondet fn bitwise_testi() -> Void {
    println("  [BIT] Bitwise operator testleri:")
    println("    12 & 10  = " + bit_and(12, 10))
    println("    12 | 10  = " + bit_or(12, 10))
    println("    12 ^ 10  = " + bit_xor(12, 10))
    println("    1 << 4   = " + bit_shl(1, 4))
    println("    256 >> 3 = " + bit_shr(256, 3))
    println("    0xFF & 0x0F = " + bit_and(255, 15))
}

// ============================================================
// BOLUM 14: BREAK VE CONTINUE
// ============================================================

nondet fn break_testi() -> Void {
    println("  [BREAK] Break testi:")
    let i = 0
    while i < 100 {
        if i == 5 {
            println("    i=5'te break!")
            break
        }
        println("    i = " + i)
        i = i + 1
    }
}

nondet fn continue_testi() -> Void {
    println("  [CONTINUE] Continue testi (cift sayilari atla):")
    for i in 0..10 {
        if i % 2 == 0 {
            continue
        }
        println("    tek: " + i)
    }
}

nondet fn break_continue_for() -> Void {
    println("  [BC-FOR] For'da break+continue:")
    for i in 0..20 {
        if i % 3 == 0 {
            continue
        }
        if i > 10 {
            println("    i>10, break!")
            break
        }
        println("    i = " + i)
    }
}

