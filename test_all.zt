}

nondet fn sezar_testi() -> Void {
    println("  [CAESAR] Sezar sifreleme (sayisal):")
    let orijinal = [1, 5, 9, 14, 20]
    let kayma = 3
    println("    Orijinal ve sifrelenmis:")
    for i in 0..5 {
        let sifre = sezar_sifrele_sayi(orijinal[i], kayma)
        println("    " + orijinal[i] + " -> " + sifre)
    }
}

// --- 11.21: Collatz conjecture ---
det fn collatz_adim(n: i64) -> i64 {
    if n == 1 {
        return 0
    }
    let kalan = n - (n / 2) * 2
    if kalan == 0 {
        return 1 + collatz_adim(n / 2)
    } else {
        return 1 + collatz_adim(n * 3 + 1)
    }
}

nondet fn collatz_testi() -> Void {
    println("  [COLLATZ] Collatz adim sayilari:")
    for i in 1..21 {
        let adim = collatz_adim(i)
        println("    n=" + i + " -> " + adim + " adim")
    }
}

// --- 11.22: Buyuk hesaplama benchmark ---
nondet fn buyuk_benchmark() -> Void {
    println("  [BENCH2] Buyuk hesaplama:")
