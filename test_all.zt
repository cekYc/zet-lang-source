// ============================================================
// BOLUM 19: UNARY OPERATORLER
// ============================================================

det fn negatif_al(n: i64) -> i64 {
    return -n
}

nondet fn unary_testi() -> Void {
    println("  [UNARY] Unary operator testi:")
    let a = 42
    println("    -42 = " + -a)
    println("    negatif_al(7) = " + negatif_al(7))
    println("    -(-5) = " + negatif_al(negatif_al(5)))
    let b = true
    println("    !true = " + !b)
    println("    !false = " + !(!b))
}

// ============================================================
// BOLUM 20: BOOL DONUSLU KARSILASTIRMA
// ============================================================

det fn esit_mi_bool(a: i64, b: i64) -> bool {
    return a == b
}

det fn buyuk_mu_bool(a: i64, b: i64) -> bool {
    return a > b
}

det fn asal_mi_bool(n: i64) -> bool {
    if n <= 1 {
        return false
    }
    if n <= 3 {
        return true
    }
    if n % 2 == 0 {
        return false
    }
    if n % 3 == 0 {
        return false
    }
    return true
}

nondet fn bool_karsilastirma_testi() -> Void {
    println("  [BOOL-CMP] Bool donuslu karsilastirma:")
    println("    5 == 5 ? " + esit_mi_bool(5, 5))
    println("    5 == 3 ? " + esit_mi_bool(5, 3))
    println("    7 > 3  ? " + buyuk_mu_bool(7, 3))
    println("    2 > 8  ? " + buyuk_mu_bool(2, 8))
    println("    7 asal mi? " + asal_mi_bool(7))
    println("    4 asal mi? " + asal_mi_bool(4))
}

