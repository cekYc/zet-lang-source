// ============================================================
// BOLUM 1: DETERMINISTIK (SAF) FONKSIYONLAR
// Sadece CPU ve RAM kullanan, I/O icermeyen fonksiyonlar.
// ============================================================

// --- 1.1: Temel Aritmetik ---
det fn topla(a: i64, b: i64) -> i64 {
    return a + b
}

det fn cikar(a: i64, b: i64) -> i64 {
    return a - b
}

det fn carp(a: i64, b: i64) -> i64 {
    return a * b
}

det fn bol(a: i64, b: i64) -> i64 {
    return a / b
}

// --- 1.2: Karsilastirma Operatorleri ---
det fn esit_mi(a: i64, b: i64) -> i64 {
    if a == b {
        return 1
    }
    return 0
}

det fn farkli_mi(a: i64, b: i64) -> i64 {
    if a != b {
        return 1
    }
    return 0
}

det fn buyuk_mu(a: i64, b: i64) -> i64 {
    if a > b {
        return 1
    }
    return 0
}

det fn kucuk_mu(a: i64, b: i64) -> i64 {
    if a < b {
        return 1
    }
    return 0
}

det fn buyuk_esit_mi(a: i64, b: i64) -> i64 {
    if a >= b {
        return 1
    }
    return 0
}

det fn kucuk_esit_mi(a: i64, b: i64) -> i64 {
    if a <= b {
        return 1
    }
    return 0
}

// --- 1.3: Rekursif Fonksiyonlar ---
det fn fibonacci(n: i64) -> i64 {
    if n <= 1 {
        return n
    }
    let a = fibonacci(n - 1)
    let b = fibonacci(n - 2)
    return a + b
}

det fn faktoriyel(n: i64) -> i64 {
    if n <= 1 {
        return 1
    }
    return n * faktoriyel(n - 1)
}

det fn us_al(taban: i64, us: i64) -> i64 {
    if us == 0 {
        return 1
    }
    return taban * us_al(taban, us - 1)
}

det fn gcd(a: i64, b: i64) -> i64 {
    if b == 0 {
        return a
    }
    let kalan = a - (a / b) * b
    return gcd(b, kalan)
}

// --- 1.4: If/Else Zincirleri ---
det fn mutlak_deger(n: i64) -> i64 {
    if n < 0 {
        return 0 - n
    } else {
        return n
    }
}

det fn maks(a: i64, b: i64) -> i64 {
    if a >= b {
        return a
    }
    return b
}

det fn min_deger(a: i64, b: i64) -> i64 {
    if a <= b {
        return a
    }
    return b
}

det fn isaret(n: i64) -> i64 {
    if n > 0 {
        return 1
    } else {
        if n < 0 {
            return 0 - 1
        } else {
            return 0
        }
    }
}

det fn siniflandir(puan: i64) -> i64 {
    if puan >= 90 {
        return 5
    } else {
        if puan >= 80 {
            return 4
        } else {
            if puan >= 70 {
                return 3
            } else {
                if puan >= 60 {
                    return 2
                } else {
                    return 1
                }
            }
        }
    }
}

// --- 1.5: Print det fonksiyonlarda (senkron I/O izinli) ---
det fn det_print_testi() -> Void {
    println("  [DET] print/println det fonksiyonda calisiyor!")
    print("  [DET] Bu satirda ")
    println("devam ediyor.")
}

// --- 1.6: String islemleri det fonksiyonlarda ---
det fn selamla(isim: String) -> String {
    return "Merhaba, " + isim
}

det fn tekrarla_sayi(n: i64) -> String {
    return "Sayi: " + n
}

// --- 1.7: Karmasik hesaplamalar ---
det fn kare_al(n: i64) -> i64 {
    return n * n
}

det fn kup_al(n: i64) -> i64 {
    return n * n * n
}

det fn ortalama_iki(a: i64, b: i64) -> i64 {
    return (a + b) / 2
}

det fn asal_mi(n: i64) -> i64 {
    if n <= 1 {
        return 0
    }
    if n <= 3 {
        return 1
    }
    let kalan2 = n - (n / 2) * 2
    if kalan2 == 0 {
        return 0
    }
    let kalan3 = n - (n / 3) * 3
    if kalan3 == 0 {
        return 0
    }
    let kalan5 = n - (n / 5) * 5
    if kalan5 == 0 {
        if n != 5 {
            return 0
        }
    }
    let kalan7 = n - (n / 7) * 7
    if kalan7 == 0 {
        if n != 7 {
            return 0
        }
    }
    return 1
}

// --- 1.8: Ic ice fonksiyon cagrilari (det -> det) ---
det fn karmasik_hesap(x: i64) -> i64 {
    let a = topla(x, 10)
    let b = carp(a, 2)
    let c = cikar(b, 5)
    return c
}

det fn zincirleme(n: i64) -> i64 {
    return topla(carp(n, 3), cikar(n, 1))
}

