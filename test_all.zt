// ============================================================
// BOLUM 6: SCOPE VE SPAWN (ESZAMANLILIK)
// ============================================================

// --- 6.1: Basit scope ---
nondet fn basit_scope_testi() -> Void {
    println("  [SCOPE] Basit scope testi:")
    scope BasitScope {
        spawn println("    [spawn 1] Merhaba scope'dan!")
        spawn println("    [spawn 2] Ben de buradayim!")
        spawn println("    [spawn 3] Paralel calisiyoruz!")
    }
    println("  [SCOPE] Tum spawn'lar bitti.")
}

// --- 6.2: Scope icinde hesaplama ---
nondet fn scope_hesap_testi() -> Void {
    println("  [SCOPE-CALC] Scope ile hesaplama:")
    let sonuc1 = fibonacci(8)
    let sonuc2 = faktoriyel(5)
    
    scope HesapScope {
        spawn println("    [spawn] Fibonacci(8) = " + sonuc1)
        spawn println("    [spawn] 5! = " + sonuc2)
    }
    println("  [SCOPE-CALC] Scope bitti.")
}

// --- 6.3: Birden fazla scope ---
nondet fn coklu_scope_testi() -> Void {
    println("  [MULTI-SCOPE] Birden fazla scope:")
    
    scope Birinci {
        spawn println("    [Scope1-A] Ilk scope, ilk gorev")
        spawn println("    [Scope1-B] Ilk scope, ikinci gorev")
    }
    println("    --- Birinci scope tamamlandi ---")
    
    scope Ikinci {
        spawn println("    [Scope2-A] Ikinci scope, ilk gorev")
        spawn println("    [Scope2-B] Ikinci scope, ikinci gorev")
    }
    println("    --- Ikinci scope tamamlandi ---")
}

