// --- 3.1: For dongusu (temel) ---
nondet fn for_testi() -> Void {
    println("  [FOR] 0'dan 5'e kadar:")
    for i in 0..5 {
        println("    i = " + i)
    }
}

// --- 3.2: For dongusu (step/by ile) ---
nondet fn for_step_testi() -> Void {
    println("  [FOR-BY] 0'dan 20'ye, 3'er 3'er:")
    for i in 0..20 by 3 {
        println("    i = " + i)
    }
}

// --- 3.3: While dongusu ---
nondet fn while_testi() -> Void {
    println("  [WHILE] Geri sayim:")
    let x = 5
    while x > 0 {
        println("    " + x)
        x = x - 1
    }
    println("    Bitti!")
}

// --- 3.4: Ic ice donguler ---
nondet fn ic_ice_dongu() -> Void {
    println("  [NESTED] Carpim tablosu (1-3):")
    for i in 1..4 {
        for j in 1..4 {
            let sonuc = i * j
            println("    " + i + " x " + j + " = " + sonuc)
        }
    }
}

// --- 3.5: If icinde dongu, dongu icinde if ---
nondet fn karisik_kontrol() -> Void {
    println("  [MIX] Cift sayilar (0-9):")
    for i in 0..10 {
        let kalan = i - (i / 2) * 2
        if kalan == 0 {
            println("    Cift: " + i)
        }
    }
}

// --- 3.6: While icinde if ---
nondet fn while_if_testi() -> Void {
    println("  [WHILE-IF] Collatz serisi (n=13):")
    let n = 13
    let adim = 0
    while n != 1 {
        println("    n=" + n)
        let kalan = n - (n / 2) * 2
        if kalan == 0 {
            n = n / 2
        } else {
            n = n * 3 + 1
        }
        adim = adim + 1
    }
    println("    n=1 (toplam " + adim + " adim)")
}

